# ─────────────────────────────────────────────────────────────
#  XEarnings — Server Environment Variables
#  Get these from: https://developer.x.com/en/portal/dashboard
# ─────────────────────────────────────────────────────────────

X_CLIENT_ID=your_client_id_here
X_CLIENT_SECRET=your_client_secret_here

# Where X sends users back after they approve — must match
# EXACTLY what you set in your X Developer App settings
REDIRECT_URI=http://localhost:3000/callback

# Any long random string — keeps sessions safe
SESSION_SECRET=change_this_to_something_long_and_random_please
